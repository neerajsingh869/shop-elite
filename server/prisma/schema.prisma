generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  passwordHash String?
  googleId     String? @unique
  avatarUrl    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[] // one user can have many refresh tokens
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id                   Int      @id
  productSlug          String
  title                String
  description          String
  category             String
  price                Decimal
  discountPercentage   Decimal
  rating               Float
  stock                Int
  tags                 String[]
  brand                String?
  sku                  String   @unique
  weight               Float
  dimensions           Json
  warrantyInformation  String
  shippingInformation  String
  availabilityStatus   String
  reviews              Review[]
  returnPolicy         String
  minimumOrderQuantity Int
  meta                 Json
  thumbnail            String
  images               String[]
}

model Review {
  id            Int      @id @default(autoincrement())
  rating        Int
  comment       String
  date          DateTime
  reviewerName  String
  reviewerEmail String
  product       Product  @relation(fields: [productId], references: [id])
  productId     Int
}
